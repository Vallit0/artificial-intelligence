<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ════════════════════════════════════════════
         IDLE STATE — Logo + Greeting + Tap to start
         ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutIdle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Personalized greeting -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            tools:text="Buenas tardes" />

        <!-- Logo: Circle + Triangle -->
        <FrameLayout
            android:id="@+id/logoContainer"
            android:layout_width="200dp"
            android:layout_height="240dp">

            <!-- Circle -->
            <View
                android:id="@+id/logoCircle"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/logo_circle" />

            <!-- Triangle -->
            <ImageView
                android:id="@+id/logoTriangle"
                android:layout_width="120dp"
                android:layout_height="90dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="50dp"
                android:src="@drawable/logo_triangle"
                android:contentDescription="Logo" />
        </FrameLayout>

        <!-- Tap to start label -->
        <TextView
            android:id="@+id/tvStartLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Práctica de Ventas"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvStartHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Toca para iniciar"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <!-- Pre-fetch status (subtle) -->
        <TextView
            android:id="@+id/tvPreFetchStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Listo para conectar"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ════════════════════════════════════════════
         CONNECTING STATE — Pill indicator
         ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutConnecting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Connection pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/connection_pill_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp">

            <ProgressBar
                android:layout_width="20dp"
                android:layout_height="20dp"
                style="?android:attr/progressBarStyleSmall" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Conectando con el agente..."
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════════════
         ACTIVE CONVERSATION
         ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutActive"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Scenario info -->
        <TextView
            android:id="@+id/tvScenarioInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            tools:text="Practicando: &quot;No me interesa&quot;" />

        <!-- Timer -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:tint="@color/indigo"
                android:contentDescription="Timer" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="00:00:00"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Timer progress bar -->
        <ProgressBar
            android:id="@+id/progressTimer"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="200dp"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_bar_fill_turquoise" />

        <!-- Speaking indicator -->
        <TextView
            android:id="@+id/tvSpeakingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="El agente está hablando..."
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/turquoise"
            android:visibility="invisible" />

        <!-- Voice Orb — Multi-layer -->
        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginTop="24dp">

            <!-- Outer glow ring -->
            <View
                android:id="@+id/orbGlowOuter"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/orb_glow_outer" />

            <!-- Middle pulse ring -->
            <View
                android:id="@+id/orbGlowMiddle"
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_gravity="center"
                android:background="@drawable/orb_glow_middle" />

            <!-- Main orb -->
            <View
                android:id="@+id/voiceOrb"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:background="@drawable/orb_background" />
        </FrameLayout>

        <!-- Pill-shaped controls bar (like webapp VoiceControls) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/pill_controls_bg"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp">

            <!-- Mute button -->
            <ImageButton
                android:id="@+id/btnMute"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/btn_mute_bg"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="@color/text_primary"
                android:scaleType="center"
                android:contentDescription="Mutear" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/border" />

            <!-- End call button -->
            <ImageButton
                android:id="@+id/btnEndCall"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/btn_end_call_bg"
                android:src="@android:drawable/ic_menu_call"
                android:tint="@color/error"
                android:scaleType="center"
                android:contentDescription="Terminar llamada" />
        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════════════
         EVALUATING STATE
         ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutEvaluating"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Evaluando tu sesión..."
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="La IA está analizando tu conversación"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════════════
         EVALUATED STATE — Full card with breakdown
         ════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/layoutEvaluation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Main evaluation card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/card_background"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Result icon circle -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp">

                    <View
                        android:id="@+id/evalIconBg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/circle_turquoise_bg" />

                    <ImageView
                        android:id="@+id/evalIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="Resultado" />
                </FrameLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvEvaluationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/turquoise"
                    tools:text="¡Misión Completada!" />

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvEvaluationSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"
                    tools:text="Siguiente escenario desbloqueado" />

                <!-- Score card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/card_muted_background"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tu puntaje"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/turquoise"
                            tools:text="85/100" />
                    </LinearLayout>

                    <!-- Score progress bar -->
                    <ProgressBar
                        android:id="@+id/progressScore"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="85"
                        android:progressDrawable="@drawable/progress_bar_fill_turquoise" />

                    <!-- Score labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50 (mínimo)"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/turquoise" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="100"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Feedback -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/feedback_card_bg"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvFeedback"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.4"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        tools:text="Buen manejo de objeciones..." />
                </LinearLayout>

                <!-- Breakdown toggle -->
                <TextView
                    android:id="@+id/tvToggleBreakdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:text="Ver desglose de puntaje"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/turquoise"
                    android:padding="8dp" />

                <!-- Breakdown details (hidden by default) -->
                <LinearLayout
                    android:id="@+id/layoutBreakdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Apertura -->
                    <include layout="@layout/item_breakdown"
                        android:id="@+id/breakdownApertura"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Escucha Activa -->
                    <include layout="@layout/item_breakdown"
                        android:id="@+id/breakdownEscucha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Manejo de Objeciones -->
                    <include layout="@layout/item_breakdown"
                        android:id="@+id/breakdownObjeciones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Propuesta de Valor -->
                    <include layout="@layout/item_breakdown"
                        android:id="@+id/breakdownPropuesta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Cierre -->
                    <include layout="@layout/item_breakdown"
                        android:id="@+id/breakdownCierre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Session duration -->
                <LinearLayout
                    android:id="@+id/layoutDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:tint="@color/text_secondary"
                        android:contentDescription="Duración" />

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        tools:text="Duración: 3:42" />
                </LinearLayout>

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRetry"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Intentar de nuevo"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textSize="13sp"
                        android:visibility="gone"
                        style="@style/Widget.Material3.Button" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContinue"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Continuar"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textSize="13sp"
                        android:visibility="gone"
                        style="@style/Widget.Material3.Button" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBackToScenarios"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:text="Volver a escenarios"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textSize="13sp"
                        android:visibility="gone"
                        style="@style/Widget.Material3.Button.OutlinedButton" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ════════════════════════════════════════════
         ERROR STATE
         ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <View
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/circle_muted_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Error de conexión"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                tools:text="No se pudo conectar al servidor" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnErrorRetry"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="Intentar de nuevo"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
