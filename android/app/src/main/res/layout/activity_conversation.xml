<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- IDLE STATE -->
    <LinearLayout
        android:id="@+id/layoutIdle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Señoriales"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Practica tus ventas con IA"
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="48dp"
            android:text="Iniciar"
            android:textSize="16sp"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/tvPreFetchStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Listo para conectar"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:visibility="gone" />
    </LinearLayout>

    <!-- CONNECTING -->
    <ProgressBar
        android:id="@+id/progressConnecting"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- ACTIVE CONVERSATION -->
    <LinearLayout
        android:id="@+id/layoutActive"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Timer -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace" />

        <!-- Speaking indicator -->
        <TextView
            android:id="@+id/tvSpeakingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="El agente está hablando..."
            android:textSize="14sp"
            android:textColor="@color/accent"
            android:visibility="invisible" />

        <!-- Orb placeholder (replace with custom view later) -->
        <View
            android:id="@+id/voiceOrb"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/orb_background" />

        <!-- Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMute"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Mutear"
                android:textAllCaps="false"
                android:layout_marginEnd="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEndCall"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Terminar"
                android:textAllCaps="false"
                android:backgroundTint="@color/error" />
        </LinearLayout>
    </LinearLayout>

    <!-- EVALUATION -->
    <LinearLayout
        android:id="@+id/layoutEvaluation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvEvaluationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvEvaluationDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:text="Intentar de nuevo"
            android:textAllCaps="false"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
