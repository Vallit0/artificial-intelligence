# ============================================
# Variables de Entorno - Señoriales
# ============================================
# Copia este archivo a .env y configura los valores

# === OBLIGATORIAS ===

# Secreto para tokens JWT (generar con: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# URL pública de la aplicación
APP_URL=http://localhost:3000

# Orígenes permitidos para CORS
CORS_ORIGIN=http://localhost:3000

# === APIS EXTERNAS ===

# ElevenLabs (IA Conversacional)
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=agent_your_agent_id

# OpenAI (Evaluación de sesiones)
OPENAI_API_KEY=sk-your_openai_api_key

# === PARA PRODUCCIÓN CON RDS EXTERNO ===
# Descomenta esta línea y configura tu URL de RDS
# DATABASE_URL=postgresql://user:password@rds-host:5432/senoriales?sslmode=require
