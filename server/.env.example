# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://senoriales:senoriales@localhost:5432/senoriales

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# App URL (for LTI redirects and password reset emails)
APP_URL=http://localhost:3000

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-default-agent-id

# ElevenLabs Agent IDs for specific scenarios (Conversational AI Agents)
# Each prospecting scenario and the final exam can use a different agent
ELEVENLABS_AGENT_PROSPECTING_PAREJA=
ELEVENLABS_AGENT_PROSPECTING_FRUTAS=
ELEVENLABS_AGENT_PROSPECTING_NEUMATICOS=
ELEVENLABS_AGENT_PROSPECTING_RESTAURANTE=
ELEVENLABS_AGENT_PROSPECTING_PARQUEO=
ELEVENLABS_AGENT_EXAMEN_FINAL=

# OpenAI Configuration (for session evaluation)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Resend (email service for password reset)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Señoriales <onboarding@resend.dev>
